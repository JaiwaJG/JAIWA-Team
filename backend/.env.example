# JAIWA Team Backend Environment Variables
#
# Copy this file to .env and fill in the actual values.
# Never commit .env to version control.

# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
TRUST_PROXY=false

# Database (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/jaiwa_db?schema=public

# JWT Secrets
# JWT_ACCESS_SECRET is preferred. JWT_SECRET is supported as a legacy fallback.
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars

# Token Expiry (seconds)
ACCESS_TOKEN_EXPIRY_SECONDS=900
REFRESH_TOKEN_EXPIRY_SECONDS=604800

# Email Service (Gmail SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
FROM_EMAIL=noreply@jaiwa.com
FROM_NAME=JAIWA Team
